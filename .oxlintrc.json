{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript"],
  "categories": {
    "correctness": "error"
  },
  "ignorePatterns": [
    "dist/**",
    "dist-main/**",
    "dist-renderer/**",
    "release/**",
    "data/**",
    "main/generated/**",
    "packages/electron-ipc-module/**",
    "packages/electron-run/**"
  ],
  "rules": {
    "typescript/no-explicit-any": "error",
    "no-unused-vars": "error"
  }
}
