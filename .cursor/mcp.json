{
  "mcpServers": {
    "angular-cli": {
      "command": "npx",
      "args": ["-y", "@angular/cli@22", "mcp"]
    },
    "shader-studio": {
      "command": "cmd",
      "args": ["/c", "node", "packages/mcp/dist/server.mjs"],
      "env": {
        "SHADER_STUDIO_MCP_PORT": "4310",
        "SHADER_STUDIO_MCP_TOKEN": "shader-studio-dev-token"
      }
    }
  }
}
