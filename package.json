{
  "name": "shader-studio",
  "version": "1.0.0",
  "private": true,
  "description": "A shader collection viewer and editor: browse, edit, tune and share WebGL shaders.",
  "keywords": [],
  "license": "ISC",
  "author": "Adel Terki",
  "type": "module",
  "main": "dist-main/main.cjs",
  "scripts": {
    "ng": "ng",
    "dev": "ng serve",
    "start": "ng serve",
    "build": "ng build",
    "clean:desktop": "node scripts/desktop/clean.mjs",
    "gen:ipc": "node scripts/gen/ipc.mjs",
    "gen:fonts": "node scripts/gen/fonts.mjs",
    "build:renderer": "ng run shader-studio:desktop:production",
    "build:main": "rollup -c --environment NODE_ENV:production",
    "build:desktop": "node scripts/desktop/build.mjs",
    "dev:desktop": "node scripts/desktop/dev.mjs",
    "typecheck:main": "tsc --noEmit -p tsconfig.main.json",
    "typecheck:preload": "tsc --noEmit -p tsconfig.preload.json",
    "pack:dir": "node scripts/desktop/build.mjs pack",
    "pack:win": "node scripts/desktop/build.mjs pack --win",
    "dist:win": "node scripts/desktop/build.mjs dist --win",
    "serve:ssr": "node dist/shader-studio/server/server.mjs",
    "test": "pnpm --filter @shader-studio/shared test && pnpm test:mcp && ng test",
    "test:watch": "ng test --watch",
    "test:mcp": "vitest run -c mcp/vitest.config.ts",
    "typecheck": "pnpm gen:ipc && pnpm --filter @shader-studio/shared typecheck && tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.spec.json --noEmit && pnpm typecheck:mcp && pnpm typecheck:main && pnpm typecheck:preload",
    "typecheck:mcp": "tsc -p mcp/tsconfig.json --noEmit",
    "check:i18n": "node scripts/check/i18n.mjs",
    "check:fonts": "node scripts/check/fonts.mjs",
    "check:ipc": "node scripts/check/ipc.mjs",
    "check": "pnpm check:i18n && pnpm check:fonts && pnpm check:ipc",
    "smoke": "node scripts/smoke.mjs",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "mcp:server": "tsx mcp/server.ts",
    "mcp:verify": "tsx mcp/verify-bridge.ts"
  },
  "dependencies": {
    "@angular/cdk": "22.0.4",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/localize": "22.0.6",
    "@angular/material": "22.0.4",
    "@angular/platform-browser": "^22.0.0",
    "@angular/platform-server": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@angular/ssr": "^22.0.6",
    "@shader-studio/shared": "workspace:*",
    "electron-updater": "6.8.9",
    "express": "^5.1.0",
    "lil-gui": "^0.21.0",
    "mediabunny": "^1.50.8",
    "monaco-editor": "^0.55.1",
    "rxjs": "~7.8.0",
    "three": "^0.185.1",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.6",
    "@angular/cli": "^22.0.6",
    "@angular/compiler-cli": "^22.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@rollup/plugin-commonjs": "^28.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-replace": "^6.0.2",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "@types/three": "^0.185.1",
    "@types/ws": "^8.18.1",
    "electron": "^40.8.0",
    "electron-builder": "^26.0.12",
    "electron-ipc-module": "workspace:*",
    "electron-run": "workspace:*",
    "jsdom": "^28.0.0",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "playwright": "^1.57.0",
    "rollup": "^4.30.1",
    "tsx": "^4.23.1",
    "typescript": "~6.0.2",
    "vitest": "^4.0.8",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": "^22.22.3 || ^24.15.0 || >=26.0.0"
  },
  "volta": {
    "node": "26.5.0"
  },
  "packageManager": "pnpm@10.28.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "esbuild"
    ]
  }
}
