{
  "name": "shader-studio",
  "version": "1.0.0",
  "description": "A shader collection viewer and editor: browse, edit, tune and share WebGL shaders.",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "volta": {
    "node": "26.5.0"
  },
  "engines": {
    "node": "^22.22.3 || ^24.15.0 || >=26.0.0"
  },
  "scripts": {
    "ng": "ng",
    "dev": "ng serve",
    "start": "ng serve",
    "build": "ng build",
    "serve:ssr": "node dist/shader-studio/server/server.mjs",
    "test": "ng test",
    "test:watch": "ng test --watch",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.spec.json --noEmit",
    "lint": "ng lint",
    "format": "prettier --write \"**/*.{ts,html,scss,json,md}\""
  },
  "dependencies": {
    "@angular/cdk": "22.0.4",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/material": "22.0.4",
    "@angular/platform-browser": "^22.0.0",
    "@angular/platform-server": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@angular/ssr": "^22.0.6",
    "express": "^5.1.0",
    "lil-gui": "^0.21.0",
    "monaco-editor": "^0.55.1",
    "rxjs": "~7.8.0",
    "three": "^0.185.1",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-eslint/builder": "22.0.0",
    "@angular/build": "^22.0.6",
    "@angular/cli": "^22.0.6",
    "@angular/compiler-cli": "^22.0.0",
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "@types/three": "^0.185.1",
    "angular-eslint": "22.0.0",
    "eslint": "^10.3.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "8.60.1",
    "vitest": "^4.0.8"
  }
}
