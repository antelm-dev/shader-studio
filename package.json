{
  "name": "shader-studio",
  "version": "1.0.0",
  "private": true,
  "description": "A shader collection viewer and editor: browse, edit, tune and share WebGL shaders.",
  "keywords": [],
  "license": "Apache-2.0",
  "author": "Adel Terki",
  "type": "module",
  "main": "dist-main/main.cjs",
  "scripts": {
    "dev": "pnpm --filter @shader-studio/renderer dev",
    "dev:server": "pnpm --filter @shader-studio/server dev",
    "build": "pnpm --filter @shader-studio/renderer build",
    "clean:desktop": "pnpm --filter @shader-studio/desktop clean",
    "gen:ipc": "pnpm --filter @shader-studio/desktop gen:ipc",
    "gen:fonts": "node scripts/gen/fonts.mjs",
    "build:renderer": "pnpm --filter @shader-studio/renderer build:desktop",
    "build:main": "pnpm --filter @shader-studio/desktop build:main",
    "build:desktop": "pnpm --filter @shader-studio/desktop build",
    "dev:desktop": "pnpm --filter @shader-studio/desktop dev",
    "typecheck:main": "pnpm --filter @shader-studio/desktop exec tsc --noEmit -p tsconfig.main.json",
    "typecheck:preload": "pnpm --filter @shader-studio/desktop exec tsc --noEmit -p tsconfig.preload.json",
    "pack:dir": "pnpm --filter @shader-studio/desktop pack:dir",
    "pack:win": "pnpm --filter @shader-studio/desktop pack:win",
    "dist:win": "pnpm --filter @shader-studio/desktop dist:win",
    "serve:ssr": "node dist/shader-studio/server/server.mjs",
    "test": "pnpm -r --if-present test",
    "test:watch": "pnpm --filter @shader-studio/renderer test:watch",
    "build:mcp": "pnpm --filter @shader-studio/mcp build",
    "test:mcp": "pnpm --filter @shader-studio/mcp build && pnpm --filter @shader-studio/mcp test",
    "pack:mcp": "pnpm --filter @shader-studio/mcp run pack:tarball",
    "typecheck": "pnpm gen:ipc && pnpm -r --if-present typecheck",
    "typecheck:mcp": "pnpm --filter @shader-studio/mcp typecheck",
    "check:i18n": "node scripts/check/i18n.mjs",
    "check:fonts": "node scripts/check/fonts.mjs",
    "check:ipc": "node scripts/check/ipc.mjs",
    "check": "pnpm check:i18n && pnpm check:fonts && pnpm check:ipc",
    "smoke": "node scripts/smoke.mjs",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "dev:mcp": "pnpm --filter @shader-studio/mcp exec tsx src/server.ts",
    "verify:mcp": "pnpm --filter @shader-studio/mcp exec tsx scripts/verify-bridge.ts"
  },
  "devDependencies": {
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "playwright": "^1.57.0"
  },
  "engines": {
    "node": "^22.22.3 || ^24.15.0 || >=26.0.0"
  },
  "volta": {
    "node": "26.5.0"
  },
  "packageManager": "pnpm@10.28.2",
  "pnpm": {
    "packageExtensions": {
      "electron-ipc-module@*": {
        "dependencies": {
          "typescript": "~6.0.2"
        }
      }
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "electron",
      "electron-ipc-module",
      "electron-run",
      "electron-winstaller",
      "esbuild",
      "rollup-plugin-electron-run"
    ]
  }
}
