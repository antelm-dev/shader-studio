{
  "name": "@shader-studio/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./model": {
      "types": "./src/model.ts",
      "default": "./src/model.ts"
    },
    "./project": {
      "types": "./src/project.ts",
      "default": "./src/project.ts"
    },
    "./pass-source": {
      "types": "./src/pass-source.ts",
      "default": "./src/pass-source.ts"
    },
    "./validate": {
      "types": "./src/validate.ts",
      "default": "./src/validate.ts"
    },
    "./mcp-protocol": {
      "types": "./src/mcp-protocol.ts",
      "default": "./src/mcp-protocol.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "typescript": "~6.0.2",
    "vitest": "^4.0.8"
  }
}
