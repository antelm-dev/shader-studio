{
  "name": "electron-run",
  "version": "0.1.0",
  "private": true,
  "description": "Rollup plugin and runner that live-reloads Electron on rebuild, with interactive restart controls.",
  "keywords": [
    "electron",
    "hmr",
    "live-reload",
    "restart",
    "rollup",
    "rollup-plugin",
    "typescript",
    "watch"
  ],
  "homepage": "https://github.com/antelm-dev/electron-run#readme",
  "bugs": "https://github.com/antelm-dev/electron-run/issues",
  "license": "MIT",
  "author": "Adel Terki",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/antelm-dev/electron-run.git"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./rollup-plugin": {
      "types": "./dist/rollup-plugin.d.ts",
      "import": "./dist/rollup-plugin.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm run build && pnpm run test"
  },
  "devDependencies": {
    "@types/node": "^22.8.6",
    "electron": "^40.8.0",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "rollup": "^4.17.2",
    "typescript": "^5.8.3",
    "vite": "^7.3.6",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "electron": ">=20.0.0",
    "rollup": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "rollup": {
      "optional": true
    }
  }
}
