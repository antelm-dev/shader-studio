{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "singleQuote": true,
  "ignorePatterns": [
    "dist/**",
    "dist-main/**",
    "dist-renderer/**",
    "release/**",
    "data/**",
    "main/generated/**",
    ".angular/**",
    "packages/electron-ipc-module/**",
    "packages/electron-run/**"
  ]
}
