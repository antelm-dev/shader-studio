{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2023"],
    "types": ["node", "electron"],
    "moduleResolution": "Bundler",
    "outDir": "./dist-main",
    "rootDir": ".",
    "sourceMap": true
  },
  "include": ["main/**/*.ts", "src/server/**/*.ts", "src/app/api/shader-api.ts"],
  "exclude": ["main/preload.ts", "main/generated/**", "**/*.spec.ts"]
}
