{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2023"],
    "types": ["node", "electron"],
    "moduleResolution": "Bundler",
    "outDir": "./dist-main",
    "rootDir": ".",
    "sourceMap": true
  },
  "include": [
    "apps/desktop/main/src/**/*.ts",
    "apps/server/src/**/*.ts",
    "apps/renderer/src/app/api/shader-api.ts"
  ],
  "exclude": ["apps/desktop/generated/**", "**/*.spec.ts"]
}
