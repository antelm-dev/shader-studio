{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "pnpm",
    "analytics": "56cc93d3-fa2e-4a94-8a1e-aebceab00ffd"
  },
  "newProjectRoot": "projects",
  "projects": {
    "shader-studio": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "outputPath": { "base": "../../dist/shader-studio" },
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "polyfills": ["@angular/localize/init"],
            "assets": [],
            "styles": [
              "src/styles.scss",
              "node_modules/monaco-editor/min/vs/editor/editor.main.css"
            ],
            "loader": {
              ".ttf": "file"
            },
            "server": "src/main.server.ts",
            "outputMode": "server",
            "security": {
              "allowedHosts": []
            },
            "ssr": {
              "entry": "../server/src/index.ts"
            }
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2.0MB",
                  "maximumError": "2.2MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "8kB",
                  "maximumError": "16kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "prebundle": { "exclude": ["@shader-studio/shared"] }
          },
          "configurations": {
            "production": {
              "buildTarget": "shader-studio:build:production"
            },
            "development": {
              "buildTarget": "shader-studio:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "desktop": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.desktop.ts",
            "outputPath": { "base": "../../dist-renderer", "browser": "" },
            "outputMode": "static",
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "polyfills": ["@angular/localize/init"],
            "assets": [],
            "styles": [
              "src/styles.scss",
              "node_modules/monaco-editor/min/vs/editor/editor.main.css"
            ],
            "loader": { ".ttf": "file" },
            "security": { "allowedHosts": [] }
          },
          "configurations": {
            "production": {
              "optimization": {
                "scripts": true,
                "styles": {
                  "minify": true,
                  "inlineCritical": false
                },
                "fonts": true
              },
              "outputHashing": "all",
              "budgets": [
                { "type": "initial", "maximumWarning": "2.0MB", "maximumError": "2.2MB" },
                { "type": "anyComponentStyle", "maximumWarning": "8kB", "maximumError": "16kB" }
              ]
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "desktop-serve": {
          "builder": "@angular/build:dev-server",
          "options": { "port": 4201, "prebundle": { "exclude": ["@shader-studio/shared"] } },
          "configurations": {
            "production": { "buildTarget": "shader-studio:desktop:production" },
            "development": { "buildTarget": "shader-studio:desktop:development" }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "buildTarget": "shader-studio:build:development",
            "runner": "vitest"
          }
        }
      }
    }
  }
}
